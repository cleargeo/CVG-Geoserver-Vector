# =============================================================================
# CVG GeoServer Vector — Environment Variables
# Copy to .env and fill in real values before running docker compose.
# NEVER commit .env to git. Use .gitignore to exclude it.
# =============================================================================

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Strong admin password — used by geoserver-init to replace GeoServer's
# default "geoserver" password on first deploy. Min 12 chars. No quotes needed.
GEOSERVER_ADMIN_PASSWORD=changeme_strong_password_here

# ── OPTIONAL OVERRIDES (defaults match production vector.cleargeo.tech) ───────

# Public proxy base URL injected into GeoServer GetCapabilities responses.
# Must match the externally-reachable domain served by Caddy.
PROXY_BASE_URL=https://vector.cleargeo.tech/geoserver

# CSRF whitelist — domain Caddy proxies requests from.
# Prevents GeoServer's CSRF filter from rejecting Caddy-forwarded admin UI requests.
GEOSERVER_CSRF_WHITELIST=vector.cleargeo.tech

# GeoServer log profile — controls log verbosity in the container.
# PRODUCTION_LOGGING  → WARN/ERROR only  (recommended for prod — low I/O)
# DEFAULT_LOGGING     → INFO             (good for staging/debug)
# VERBOSE_LOGGING     → DEBUG            (very chatty — only for deep troubleshooting)
GEOSERVER_LOG_PROFILE=PRODUCTION_LOGGING

# ── INIT SERVICE ──────────────────────────────────────────────────────────────
# These are only used by the geoserver-init one-shot service (--profile init).
# They default to the values above if not set separately.

# GEOSERVER_ADMIN_USER=admin     # default: admin — change only if you rename the admin account
# SKIP_IF_DONE=true              # default: true — set false to force re-init

# ── NOTES ─────────────────────────────────────────────────────────────────────
# To run the init service on first deploy:
#   docker compose -f docker-compose.prod.yml --profile init up geoserver-init
#
# To force re-init (e.g., password reset):
#   docker compose -f docker-compose.prod.yml run --rm \
#     -e SKIP_IF_DONE=false geoserver-init
