# CVG GeoServer Vector -- LOCAL DEVELOPMENT (HTTP only)
{
    auto_https off
}

:80 {
    handle / { root * /srv/portal; file_server }
    handle /portal/* { uri strip_prefix /portal; root * /srv/portal; file_server }
    reverse_proxy geoserver-vector-dev:8080 {
        header_up X-Forwarded-For   {remote_host}
        header_up X-Forwarded-Proto http
        header_up Host              {host}
        flush_interval -1
        transport http {
            dial_timeout 30s; response_header_timeout 60s
            read_timeout 300s; write_timeout 300s
        }
    }
    @options { method OPTIONS }
    handle @options {
        header Access-Control-Allow-Origin "*"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, Accept"
        respond 204
    }
    header Access-Control-Allow-Origin "*"
    encode gzip
    log { output stdout; format console }
}
