# =============================================================================
# CVG GeoServer Vector — Caddyfile
# (c) Clearview Geographic, LLC — Proprietary
# Target: vector.cleargeo.tech  →  geoserver-vector:8080
#         Portal served from:  /srv/portal/index.html
# =============================================================================
# Requirements before first start:
#   1. DNS A record:  vector.cleargeo.tech  →  public IP (see docker-compose.prod.yml)
#   2. Ports 80 + 443 open inbound (FortiGate VIP or VM451 already handles 443)
#   3. Email below kept current for Let's Encrypt expiry notices
#   4. Mount ./caddy/portal → /srv/portal (done in docker-compose.prod.yml)
# =============================================================================

{
    email azelenski@clearviewgeographic.com

    # Use Let's Encrypt only — disables ZeroSSL fallback
    # Switch to staging URL to test without LE rate limits:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
    acme_ca https://acme-v02.api.letsencrypt.org/directory

    # Trust VM451 Caddy reverse proxy (10.10.10.200) for X-Forwarded-For
    # so that remote_ip matchers see real client IPs, not the proxy IP.
    servers {
        trusted_proxies static 10.10.10.200
    }
}

# =============================================================================
# HTTP block — handles plain-HTTP requests forwarded by VM451 Caddy.
# VM451 terminates TLS for vector.cleargeo.tech and proxies HTTP here.
# Without this block Caddy auto-redirects HTTP→HTTPS, causing a redirect loop.
# =============================================================================
http://vector.cleargeo.tech {

    # Portal landing page
    handle / {
        root * /srv/portal
        file_server
    }

    handle /portal/* {
        uri strip_prefix /portal
        root * /srv/portal
        file_server
    }

    handle /health {
        rewrite * /geoserver/ows
        reverse_proxy geoserver-vector:8080 {
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto https
        }
    }

    # Admin UI — LAN only (real IP resolved via servers.trusted_proxies above)
    route /geoserver/web/* {
        @blocked not remote_ip 10.10.10.0/24 10.10.20.0/24 127.0.0.1/8
        handle @blocked {
            root * /srv/portal
            rewrite * /403.html
            file_server
            header Cache-Control "no-store"
        }
        reverse_proxy geoserver-vector:8080
    }

    # REST API — LAN only
    route /geoserver/rest/* {
        @blocked not remote_ip 10.10.10.0/24 10.10.20.0/24 127.0.0.1/8
        handle @blocked {
            respond `{"error":"GeoServer REST API accessible from CVG LAN only","status":403}` 403 {
                close
            }
        }
        reverse_proxy geoserver-vector:8080
    }

    # GWC REST — LAN only
    route /geoserver/gwc/rest/* {
        @blocked not remote_ip 10.10.10.0/24 10.10.20.0/24 127.0.0.1/8
        handle @blocked {
            respond `{"error":"GeoWebCache REST accessible from CVG LAN only","status":403}` 403 {
                close
            }
        }
        reverse_proxy geoserver-vector:8080
    }

    # Static status probe — must come BEFORE catch-all reverse_proxy
    handle /status {
        respond "OK" 200
    }

    # OWS / WFS / WMS / Vector Tiles — public GIS endpoints (catch-all)
    reverse_proxy geoserver-vector:8080 {
        header_up X-Forwarded-For   {remote_host}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-Proto https
        header_up Host              {host}
        transport http {
            dial_timeout            30s
            response_header_timeout 60s
            read_timeout            300s
            write_timeout           300s
        }
        flush_interval -1
        health_uri      /geoserver/ows
        health_interval 30s
        health_timeout  10s
    }

    handle_errors 502 503 504 {
        root * /srv/portal
        rewrite * /index.html
        file_server
        header Cache-Control "no-store"
    }

    # CORS
    @options method OPTIONS
    handle @options {
        header Access-Control-Allow-Origin  "*"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, Accept"
        header Access-Control-Max-Age       "86400"
        respond 204
    }
    header Access-Control-Allow-Origin "*"

    encode gzip zstd

    log {
        output file /var/log/caddy/geoserver-vector-http.log {
            roll_size     50MiB
            roll_keep     7
        }
        format json
    }
}

# ── GeoServer Vector public endpoint (HTTPS — direct FortiGate VIP route) ────
vector.cleargeo.tech {

    # ── Portal landing page — served from /srv/portal ─────────────────────────
    # The root "/" and "/portal" serve the CVG proprietary data access portal.
    # Any path NOT under /geoserver/* is handled by the file server first.
    # This gives a professional branded entry point instead of the raw GeoServer UI.
    handle / {
        root * /srv/portal
        file_server
    }

    # Serve portal assets directory (CSS, JS, images if separate files are added)
    handle /portal/* {
        uri strip_prefix /portal
        root * /srv/portal
        file_server
    }

    # Health check endpoint — lightweight status for uptime monitoring tools
    # Rewrites /health → /geoserver/ows and proxies to GeoServer.
    # GeoServer OWS dispatcher returns a tiny page in <100ms.
    handle /health {
        rewrite * /geoserver/ows
        reverse_proxy geoserver-vector:8080 {
            header_up X-Forwarded-For   {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # ── Admin UI — restrict to CVG LAN + Proxmox network only ────────────────
    # The GeoServer admin web UI should NEVER be exposed to the public internet.
    route /geoserver/web/* {
        @blocked not remote_ip 10.10.10.0/24 10.10.20.0/24 127.0.0.1/8
        handle @blocked {
            root * /srv/portal
            rewrite * /403.html
            file_server
            header Cache-Control "no-store"
        }
        reverse_proxy geoserver-vector:8080
    }

    # ── REST API — restrict to CVG LAN only ──────────────────────────────────
    # The GeoServer REST API allows layer/store/workspace management.
    # Exposing it publicly is a critical security risk — LAN-only.
    route /geoserver/rest/* {
        @blocked not remote_ip 10.10.10.0/24 10.10.20.0/24 127.0.0.1/8
        handle @blocked {
            respond `{"error":"GeoServer REST API accessible from CVG LAN only","status":403}` 403 {
                close
            }
        }
        reverse_proxy geoserver-vector:8080
    }

    # ── GWC REST — restrict tile cache management to LAN ─────────────────────
    route /geoserver/gwc/rest/* {
        @blocked not remote_ip 10.10.10.0/24 10.10.20.0/24 127.0.0.1/8
        handle @blocked {
            respond `{"error":"GeoWebCache REST accessible from CVG LAN only","status":403}` 403 {
                close
            }
        }
        reverse_proxy geoserver-vector:8080
    }

    # ── Static status probe ───────────────────────────────────────────────────
    # Returns 200 immediately without touching GeoServer upstream.
    # Used by FortiGate health monitors, uptime checkers, and load balancers.
    # MUST come BEFORE the bare reverse_proxy catch-all below.
    handle /status {
        respond "OK" 200
    }

    # ── WPS — restrict to CVG LAN only ───────────────────────────────────────
    # WPS Execute jobs consume significant CPU + memory (geometry processing,
    # spatial joins, large feature set operations). Never expose to public internet.
    route /geoserver/wps* {
        @wps-blocked not remote_ip 10.10.10.0/24 10.10.20.0/24 127.0.0.1/8
        handle @wps-blocked {
            respond `{"error":"WPS geoprocessing accessible from CVG LAN only","status":403}` 403 {
                close
            }
        }
        reverse_proxy geoserver-vector:8080 {
            header_up X-Forwarded-For   {remote_host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Host              {host}
            transport http {
                dial_timeout            30s
                # WPS chained geoprocessing jobs can run for several minutes
                response_header_timeout 300s
                read_timeout            600s
                write_timeout           600s
            }
            flush_interval -1
        }
    }

    # ── OGC API (Features / Tiles) — public JSON REST endpoints ─────────────
    # GeoServer OGC API dispatcher at /geoserver/ogc/*.
    # Serves GeoJSON feature collections, tile matrix sets, and queryables.
    # Public endpoint — layer-level security enforced by GeoServer ACL rules.
    route /geoserver/ogc/* {
        reverse_proxy geoserver-vector:8080 {
            header_up X-Forwarded-For   {remote_host}
            header_up X-Real-IP         {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Host              {host}
            transport http {
                dial_timeout            30s
                response_header_timeout 60s
                read_timeout            120s
                write_timeout           120s
            }
            flush_interval -1
        }
    }

    # ── OWS / WFS / WMS / Vector Tiles — public GIS service endpoints (catch-all)
    reverse_proxy geoserver-vector:8080 {
        # Pass real client IP so GeoServer access logs + WFS request tracking work
        header_up X-Forwarded-For   {remote_host}
        header_up X-Real-IP         {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up Host              {host}

        # Timeouts tuned for vector service:
        #   response_header: 60s  — WFS GetFeature (index lookup, PostGIS query)
        #   read/write:      300s — WFS GetFeature large result sets (100k+ features)
        transport http {
            dial_timeout            30s
            response_header_timeout 60s
            read_timeout            300s
            write_timeout           300s
        }

        # Stream WFS feature responses immediately — critical for large GeoJSON
        # payloads so clients receive data progressively rather than waiting for
        # full response buffering
        flush_interval -1

        # Lightweight health check — /geoserver/ows with no params returns a tiny
        # dispatcher page in <100ms vs ~300KB WFS GetCapabilities XML
        health_uri      /geoserver/ows
        health_interval 30s
        health_timeout  10s
    }

    # ── Error handling — serve portal when GeoServer is unreachable ───────────
    # Catches 502/503/504 from the upstream GeoServer (restarting, OOM, etc.)
    # and returns the portal landing page instead of a bare Caddy error screen.
    handle_errors 502 503 504 {
        root * /srv/portal
        rewrite * /index.html
        file_server
        header Cache-Control "no-store"
    }

    # ── Cache-Control for OGC capability documents ────────────────────────────
    # GetCapabilities responses are expensive to generate but change infrequently.
    # CDN/proxy layers and QGIS/ArcGIS clients can cache these safely for 5 min.
    @capabilities {
        path_regexp cap [Rr]equest=(?i)GetCapabilities
    }
    header @capabilities {
        Cache-Control "public, max-age=300, stale-while-revalidate=60"
        Vary          "Accept-Encoding, Origin"
    }

    # ── Security headers ──────────────────────────────────────────────────────
    header {
        X-Frame-Options            "SAMEORIGIN"
        X-Content-Type-Options     "nosniff"
        Strict-Transport-Security  "max-age=31536000; includeSubDomains; preload"
        Referrer-Policy            "strict-origin-when-cross-origin"
        # XSS protection for older browsers
        X-XSS-Protection           "1; mode=block"
        # CSP: GeoServer admin UI needs inline scripts/styles
        # Portal page uses inline CSS/JS (self-contained single file)
        Content-Security-Policy    "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; frame-ancestors 'self'; object-src 'none'; connect-src 'self' https://vector.cleargeo.tech"
        # WFS consumers don't need device APIs
        Permissions-Policy         "geolocation=(), camera=(), microphone=(), payment=()"
        -Server
        -X-Powered-By
    }

    # ── CORS — allow GIS clients to consume WFS/WMS/Vector Tiles ─────────────
    # Needed for: QGIS web viewer, ArcGIS Online, Leaflet/OpenLayers/MapboxGL,
    #             CVG wizard vector overlays, web map applications
    @options {
        method OPTIONS
    }
    handle @options {
        header Access-Control-Allow-Origin  "*"
        header Access-Control-Allow-Methods "GET, POST, OPTIONS"
        header Access-Control-Allow-Headers "Content-Type, Authorization, Accept"
        header Access-Control-Max-Age       "86400"
        respond 204
    }
    header Access-Control-Allow-Origin "*"

    # ── GWC tile caching — allow browsers/CDNs to cache rendered tiles ────────
    # Vector tiles (MVT/PBF) and WMS raster tiles from GWC are cacheable.
    # 24h browser cache + stale-while-revalidate prevents repeated tile fetches.
    @gwc-tiles {
        path /geoserver/gwc/service/*
    }
    header @gwc-tiles {
        Cache-Control "public, max-age=86400, stale-while-revalidate=3600"
        Vary          "Accept-Encoding"
    }

    # ── Dynamic WFS/OWS — never cache live feature responses ─────────────────
    # WFS GetFeature must always return current data from GeoServer's stores
    @ows-dynamic {
        path /geoserver/ows* /geoserver/wfs* /geoserver/wms*
    }
    header @ows-dynamic Cache-Control "no-store, no-cache, must-revalidate"

    # ── REST API — no-cache for management operations ─────────────────────────
    @rest-api {
        path /geoserver/rest/*
    }
    header @rest-api {
        Cache-Control "no-store"
        X-Content-Type-Options "nosniff"
    }

    # ── Request body limits ───────────────────────────────────────────────────
    # WFS-T (transactional) POST bodies + WFS GetFeature with large filter XML.
    # 50 MB ceiling is generous for any legitimate WFS request payload.
    request_body {
        max_size 50MB
    }

    # ── Compression ───────────────────────────────────────────────────────────
    # GML, GeoJSON, KML, and WFS XML capability documents compress extremely well.
    # Vector tile (MVT/PBF) responses are already gzip-compressed by GeoServer.
    # Portal HTML compresses well too.
    encode gzip zstd

    # ── Structured access log ─────────────────────────────────────────────────
    log {
        output file /var/log/caddy/geoserver-vector-access.log {
            roll_size     100MiB
            roll_keep     14
            roll_keep_for 336h    # 14 days
        }
        format json
    }
}
